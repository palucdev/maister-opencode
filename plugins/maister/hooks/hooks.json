{
  "description": "AI SDLC plugin hooks for orchestrator state preservation",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-compact-reminder.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
